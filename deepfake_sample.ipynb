import os
import torch
import librosa
import pandas as pd
import warnings
from transformers import Wav2Vec2FeatureExtractor, Wav2Vec2ForSequenceClassification

# Suppress minor audio warnings for a cleaner terminal output
warnings.filterwarnings("ignore")

# ==========================================
# 1. CONFIGURATION
# ==========================================
AUDIO_FOLDER = "./audio_samples"  # Replace with the path to your folder of audio files
OUTPUT_FILE = "deepfake_analysis_results.csv"
PROBABILITY_THRESHOLD = 0.50
TARGET_SAMPLE_RATE = 16000  # Wav2Vec models require exactly 16kHz audio

# We are using a generic Wav2Vec2 classification model structure here. 
# Swap this string out if you find a specific deepfake model on Hugging Face.
MODEL_NAME = "superb/wav2vec2-base-superb-ks" 

print("Loading AI Model into memory... (This may take a moment)")
# Load the feature extractor (cleans the data) and the model (does the math)
processor = Wav2Vec2FeatureExtractor.from_pretrained(MODEL_NAME)
model = Wav2Vec2ForSequenceClassification.from_pretrained(MODEL_NAME)

# Move model to GPU if available for faster processing
device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
model.to(device)

# ==========================================
# 2. THE ALGORITHM
# ==========================================
def analyze_audio_directory(directory_path):
    results = []
    
    # Get all .wav or .mp3 files in the folder
    valid_extensions = ('.wav', '.mp3', '.flac')
    audio_files = [f for f in os.listdir(directory_path) if f.lower().endswith(valid_extensions)]
    
    print(f"Found {len(audio_files)} audio files. Starting analysis...\n")

    for filename in audio_files:
        file_path = os.path.join(directory_path, filename)
        
        try:
            # --- A. Preprocessing ---
            # Librosa automatically converts it to mono and forces the 16kHz sample rate
            audio_array, _ = librosa.load(file_path, sr=TARGET_SAMPLE_RATE)
            
            # --- B. Feature Extraction ---
            # Convert raw audio into the mathematical format the model expects
            inputs = processor(audio_array, sampling_rate=TARGET_SAMPLE_RATE, return_tensors="pt", padding=True)
            
            # Move inputs to the same device as the model (CPU or GPU)
            input_values = inputs.input_values.to(device)

            # --- C. Model Inference ---
            with torch.no_grad(): # Tells PyTorch we are just predicting, not training
                logits = model(input_values).logits
            
            # Convert the raw model output into a probability percentage (0.0 to 1.0)
            probabilities = torch.softmax(logits, dim=-1)
            
            # Assuming the model outputs [Probability_Authentic, Probability_Fake]
            # We grab the score for "Fake" (Index 1)
            # *Note: The exact index depends on the specific model's training.*
            fake_score = probabilities[0][1].item() 

            # --- D. Classification ---
            if fake_score >= PROBABILITY_THRESHOLD:
                label = "Deepfake"
            else:
                label = "Authentic"

            # --- E. Record Data ---
            results.append({
                "File Name": filename,
                "Classification": label,
                "Fake Probability": round(fake_score, 4)
            })
            
            print(f"Analyzed: {filename} | Result: {label} ({fake_score:.2f})")

        except Exception as e:
            print(f"Error processing {filename}: {e}")

    return results

# ==========================================
# 3. EXECUTE & EXPORT
# ==========================================
if __name__ == "__main__":
    # Run the pipeline
    final_data = analyze_audio_directory(AUDIO_FOLDER)
    
    # Convert the list of results into a pandas DataFrame (a spreadsheet format)
    df = pd.DataFrame(final_data)
    
    # Save to CSV
    df.to_csv(OUTPUT_FILE, index=False)
    print(f"\nAnalysis complete! Results saved successfully to {OUTPUT_FILE}")
